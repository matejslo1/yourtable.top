# ============================================
# YourTable.top - Production Environment
# ============================================
# Kopiraj v .env in izpolni svoje vrednosti

# ---- Supabase ----
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Database (Supabase PostgreSQL) ----
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxxx:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# ---- API Server ----
PORT=3001
NODE_ENV=production
APP_URL=https://app.yourtable.top
CORS_ORIGINS=https://app.yourtable.top,https://widget.yourtable.top

# ---- Frontend (build-time) ----
VITE_API_URL=https://api.yourtable.top
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ---- Email (Resend) ----
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourtable.top

# ---- SMS (Twilio) ----
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+386...

# ---- Stripe (neobvezno za start) ----
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
