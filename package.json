{
  "name": "yourtable",
  "version": "1.0.0",
  "private": true,
  "description": "YourTable.top - SaaS reservation platform for restaurants",
  "scripts": {
    "dev": "pnpm --parallel --filter './packages/*' dev",
    "dev:api": "pnpm --filter @yourtable/api dev",
    "dev:web": "pnpm --filter @yourtable/web dev",
    "dev:widget": "pnpm --filter @yourtable/widget dev",
    "build": "pnpm --filter './packages/*' build",
    "build:api": "pnpm --filter @yourtable/api build",
    "build:web": "pnpm --filter @yourtable/web build",
    "lint": "pnpm --parallel --filter './packages/*' lint",
    "typecheck": "pnpm --parallel --filter './packages/*' typecheck",
    "test": "pnpm --parallel --filter './packages/*' test",
    "db:generate": "pnpm --filter @yourtable/api db:generate",
    "db:push": "pnpm --filter @yourtable/api db:push",
    "db:migrate": "pnpm --filter @yourtable/api db:migrate",
    "db:seed": "pnpm --filter @yourtable/api db:seed",
    "db:studio": "pnpm --filter @yourtable/api db:studio",
    "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf {} + && find . -name 'dist' -type d -prune -exec rm -rf {} +"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
